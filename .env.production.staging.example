# ============================================================
# Tribes.app — STAGING Environment Variables
# ============================================================
# Copy this to .env.production ON THE STAGING BOX and fill in real values.
# NEVER commit the filled-in file to git.
#
# This is the same file name the deploy engine expects (.env.production);
# the values here just point at the staging domains and gate the site.
# ============================================================

# === Staging markers ===
# Selects the basic-auth-gated Caddyfile (see docker-compose.prod.yml).
CADDYFILE_PATH=./Caddyfile.staging
# Guards the staging-only seed script so it can never run against prod.
TRIBES_ENV=staging
# NOTE: basic-auth credentials are inlined directly in Caddyfile.staging — a
# bcrypt hash contains '$', which breaks both `source .env.production` (set -u)
# and docker-compose interpolation. Do NOT put the hash here.

# === Domains (used by Caddy reverse proxy) ===
APP_DOMAIN=staging.tribes.app
WS_DOMAIN=ws.staging.tribes.app
MEDIA_DOMAIN=media.staging.tribes.app

# === App URL ===
NEXT_PUBLIC_APP_URL=https://staging.tribes.app
NEXT_PUBLIC_WS_RELAY_URL=wss://ws.staging.tribes.app

# === Session & Security [REQUIRED] ===
# Generate fresh, independent secrets for staging: openssl rand -hex 32
SESSION_SECRET=
INTERNAL_API_SECRET=

# === Database ===
DATABASE_URL=file:/app/data/tribes.db
TURSO_DATABASE_URL=http://sqld:8080
# TURSO_AUTH_TOKEN=

# === WebAuthn / Passkeys [REQUIRED] ===
WEBAUTHN_RP_ID=staging.tribes.app
WEBAUTHN_RP_NAME="Tribes (staging)"
WEBAUTHN_ORIGIN=https://staging.tribes.app
# Set once the staging native app flavor exists (Phase 3), to the staging
# Android signing key's apk-key-hash.
# WEBAUTHN_ANDROID_ORIGIN=

# === AI Configuration ===
AI_BASE_URL=http://your-ai-host:8000/v1
AI_API_KEY=
AI_MODEL=default

# === S3 Media Storage (SeaweedFS — internal Docker hostname) ===
S3_ENDPOINT=http://seaweedfs-filer:8333
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=tribes-staging-key
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=tribes-media
S3_PUBLIC_ENDPOINT=https://media.staging.tribes.app

# === Rate Limiting (Valkey — internal Docker hostname) ===
VALKEY_URL=redis://valkey:6379

# === Google OAuth ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://staging.tribes.app/api/auth/google/callback

# === Stripe [TEST MODE ONLY on staging] ===
# Use sk_test_ keys — never live keys on staging.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === Email (SMTP — Google Workspace relay, IP-only auth) ===
# The staging box IP must be added to the Workspace SMTP relay allowlist.
# Leave SMTP_HOST unset to silently skip email instead.
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
# EMAIL_FROM clearly marks staging mail so it isn't mistaken for production.
# Quote the WHOLE value (incl. <addr>) — this file is shell-sourced, so an
# unquoted `<...>` would be parsed as a redirection and break the deploy.
EMAIL_FROM="Tribes (staging) <noreply@tribes.app>"

# === Cron Jobs ===
# CRON_SECRET=

# === Push Notifications (VAPID) ===
# Optional on staging; omit FCM/APNs keys to run push in mock mode.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@tribes.app

# === Logging ===
LOG_LEVEL=debug

# === NSFW geo gate ===
GEOIP_DB_PATH=/app/geoip/GeoLite2-City.mmdb
# Optional on staging — without a DB the geo gate resolves all regions 'open'.
GEOIPUPDATE_ACCOUNT_ID=
GEOIPUPDATE_LICENSE_KEY=
