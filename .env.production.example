# ============================================================
# Tribes.app — Production Environment Variables
# ============================================================
# Copy this to .env.production and fill in real values.
# NEVER commit .env.production to git.
# See docs/production-secrets.md for secret generation guide.
#
# Docker service hostnames (internal network):
#   app, ws-relay, postgres, pgbouncer, valkey, seaweedfs-filer, caddy
# ============================================================

# === Domains (used by Caddy reverse proxy) ===
APP_DOMAIN=tribes.app
WS_DOMAIN=ws.tribes.app
MEDIA_DOMAIN=media.tribes.app

# === App URL ===
NEXT_PUBLIC_APP_URL=https://tribes.app
NEXT_PUBLIC_WS_RELAY_URL=wss://ws.tribes.app

# === Session & Security [REQUIRED] ===
# Generate: openssl rand -hex 32
SESSION_SECRET=
# Shared secret for the app <-> ws-relay internal channel. REQUIRED in production:
# both the app and the ws-relay container read this (same value), and internal
# pushes/callbacks fail closed if it is unset. Generate: openssl rand -hex 32
INTERNAL_API_SECRET=

# === Database (PostgreSQL) [REQUIRED] ===
# The stack runs Postgres (service `postgres`) behind pgbouncer (transaction pool mode),
# both on the internal Docker network. Generate independent passwords: openssl rand -hex 24
# POSTGRES_PASSWORD is the `tribes` superuser; the `postgres` container is created with
# it on FIRST boot (changing it later needs a manual ALTER USER or a volume wipe).
# TRIBES_APP_PASSWORD is the least-priv `tribes_app` role — pgbouncer is configured for
# both roles, and in production the APP connects as `tribes_app` (create that role once
# with a GRANT of table privileges; it is NOT auto-created by the postgres image).
POSTGRES_PASSWORD=
TRIBES_APP_PASSWORD=
# App → pgbouncer (pooled) as the least-priv role. Embed TRIBES_APP_PASSWORD verbatim.
# Migrations do NOT use this — remote_deploy.sh runs drizzle-kit against the postgres
# container directly as the `tribes` superuser (derived from POSTGRES_PASSWORD), because
# a transaction-pooled connection can't hold the session a migration needs.
DATABASE_URL=postgresql://tribes_app:REPLACE_WITH_TRIBES_APP_PASSWORD@pgbouncer:5432/tribes

# === WebAuthn / Passkeys [REQUIRED] ===
WEBAUTHN_RP_ID=tribes.app
WEBAUTHN_RP_NAME=Tribes.app
WEBAUTHN_ORIGIN=https://tribes.app
# [OPTIONAL] Android native origin for Capacitor passkey bridge.
# Format: android:apk-key-hash:<base64url-sha256-cert-fingerprint>
# Supports a comma-separated list of multiple Android origins (e.g. upload key, Google Play delivery key, and debug key).
# WEBAUTHN_ANDROID_ORIGIN=

# === AI Configuration ===
AI_BASE_URL=http://your-ai-host:8000/v1
AI_API_KEY=
AI_MODEL=default

# === S3 Media Storage (SeaweedFS — internal Docker hostname) ===
S3_ENDPOINT=http://seaweedfs-filer:8333
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=tribes-prod-key
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=tribes-media
S3_PUBLIC_ENDPOINT=https://media.tribes.app

# === Rate Limiting (Valkey — internal Docker hostname) ===
VALKEY_URL=redis://valkey:6379

# === WebSocket Relay ===
# SESSION_SECRET is shared — the relay reads it as JWT_SECRET

# === Google OAuth ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://tribes.app/api/auth/google/callback

# === Stripe [REQUIRED for billing] ===
# Use sk_live_ prefix for production
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === Email (SMTP) ===
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Tribes.app" <noreply@tribes.app>

# === Cron Jobs ===
# Generate: openssl rand -hex 16
# CRON_SECRET=

# === CSAM Detection (PDQ + NCMEC Direct) ===
# PDQ hashing is local WASM — no API key needed for the hashing step.
# Register with NCMEC ESP program for the hash list + reporting credentials:
#   Email: espteam@ncmec.org | Subject: ESP Registration — Tribes.app
# PDQ_HASH_LIST_PATH=/app/data/ncmec-hashes.bin
# NCMEC_ESP_ID=
# NCMEC_ESP_PASSWORD=
# NCMEC_SKIP_REPORT=false

# === Push Notifications (VAPID) ===
# Generate: npx web-push generate-vapid-keys --json
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@tribes.app

# === Logging ===
LOG_LEVEL=info
# NODE_ENV is set in the Dockerfile

# === NSFW geo gate (issue #32) ===
# App reads the GeoLite2-City DB mounted at /app/geoip (see docker-compose.prod.yml).
GEOIP_DB_PATH=/app/geoip/GeoLite2-City.mmdb
# MaxMind creds → remote_deploy.sh auto-fetches + weekly-refreshes the DB. Without
# these, rsync the .mmdb to /opt/tribes/geoip/ yourself (no auto-refresh), and the
# verify/block tiers stay INERT (all regions resolve 'open') until the DB is present.
GEOIPUPDATE_ACCOUNT_ID=
GEOIPUPDATE_LICENSE_KEY=
