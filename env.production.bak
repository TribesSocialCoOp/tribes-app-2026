# ============================================================
# Tribes.app — Production Environment Variables
# ============================================================
# Copy this to .env.production and fill in real values.
# NEVER commit .env.production to git.
# See docs/production-secrets.md for secret generation guide.
#
# Docker service hostnames (internal network):
#   app, ws-relay, sqld, valkey, seaweedfs-filer, caddy
# ============================================================

# === Domains (used by Caddy reverse proxy) ===
APP_DOMAIN=tribes.app
WS_DOMAIN=ws.tribes.app
MEDIA_DOMAIN=media.tribes.app

# === App URL ===
NEXT_PUBLIC_APP_URL=https://tribes.app
NEXT_PUBLIC_WS_RELAY_URL=wss://ws.tribes.app
NEXT_PUBLIC_INVITE_ONLY=true

# === Session & Security [REQUIRED] ===
# Generate: openssl rand -hex 32
SESSION_SECRET=804752d8d6e0a5bcfb0027ed1787ab7114a982e593a09aa6aaeb875308a8f43d

# === Database ===
# Local SQLite replica inside the container
DATABASE_URL=postgresql://tribes_app:ef59f6fa60ff860b70967f15e15469b93120289d1f04d07fc84ac82b5e1ade3d@pgbouncer:5432/tribes
TRIBES_APP_PASSWORD=ef59f6fa60ff860b70967f15e15469b93120289d1f04d07fc84ac82b5e1ade3d
# sqld sync target (internal Docker hostname)
# TURSO_AUTH_TOKEN=   # Uncomment if sqld auth is enabled

# === WebAuthn / Passkeys [REQUIRED] ===
WEBAUTHN_RP_ID=tribes.app
WEBAUTHN_RP_NAME=Tribes.app
WEBAUTHN_ORIGIN=https://tribes.app


# === S3 Media Storage (SeaweedFS — internal Docker hostname) ===
S3_ENDPOINT=http://seaweedfs-filer:8333
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=tribes-prod-key
S3_SECRET_ACCESS_KEY=6e109bee645d0be3dff8bf5da675ac5f965880dba0f15f18e8c32dbac8239f40
S3_BUCKET_NAME=tribes-media
S3_PUBLIC_ENDPOINT=https://media.tribes.app

# === Rate Limiting (Valkey — internal Docker hostname) ===
VALKEY_URL=redis://valkey:6379

# === WebSocket Relay ===
# SESSION_SECRET is shared — the relay reads it as JWT_SECRET

# === Google OAuth ===
GOOGLE_CLIENT_ID=90645911395-cu3i5rfklgqcq1ghh0hi00bvhspkpqrs.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=https://tribes.app/api/auth/google/callback

# === Stripe [REQUIRED for billing] ===
# Get from dashboard.stripe.com → Developers → API Keys
# Use sk_live_ / pk_live_ for production, sk_test_ / pk_test_ for staging
STRIPE_SECRET_KEY=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
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=whsec_5vYtBZlEy3fne8K3ohrNLaCSCxxaAxIO

# === Email (SMTP — Google Workspace Relay) ===
# 1. admin.google.com → Account → Domains → Add a domain → tribes.app
#    (verify with TXT record via: linode-cli domains records-create $DOMAIN_ID --type TXT ...)
# 2. Create user: noreply@tribes.app in Workspace
# 3. Apps → Google Workspace → Gmail → Routing → SMTP relay service
#    → Add rule: allow your Hetzner prod IP, require TLS, any address in domain
# 4. Generate App Password on the noreply account (Security → App Passwords)
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@tribes.app
SMTP_PASS=
EMAIL_FROM='Tribes.app <noreply@tribes.app>'

# === Cron Jobs ===
CRON_SECRET=99c1f7bd52d6915f5d55e5a411381832

# === CSAM Detection (PDQ + NCMEC Direct) ===
# PDQ hashing is local WASM — no API key needed for the hashing step.
# Register with NCMEC ESP program for the hash list + reporting credentials:
#   Email: espteam@ncmec.org | Subject: ESP Registration — Tribes.app
# PDQ_HASH_LIST_PATH=/app/data/ncmec-hashes.bin
# NCMEC_ESP_ID=
# NCMEC_ESP_PASSWORD=
# NCMEC_SKIP_REPORT=false

# === Push Notifications (VAPID) ===
# Generated via: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BLJUvP0kGzxR5kB66PN799U2r5F1RW1ncFRgk_GT3ZQEFW4nS3XsAztPncGcreKBEVLJs8v7trEsNlImqlFVZGA
VAPID_PRIVATE_KEY=_z-FT5XpmvDlG7FxLrEwW78DpBi9HQc-37TL_78Zh6w
VAPID_SUBJECT=mailto:noreply@tribes.app

# === Logging ===
LOG_LEVEL=info
# NODE_ENV is set in the Dockerfile
BILLING_ENABLED=true

# === Bot Protection (Cloudflare Turnstile) ===
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADCmqoHkEuxi1B_f
TURNSTILE_SECRET_KEY=0x4AAAAAADCmqsNZe8hnR5csYRai6sUJCX4

# === PostgreSQL Password ===
POSTGRES_PASSWORD=87b1da4a5a86d17a48cb3e4a6063ff0399bd6eabd6f9c81bc0c0d6d91773ffad
MIGRATION_DATABASE_URL=postgresql://tribes:87b1da4a5a86d17a48cb3e4a6063ff0399bd6eabd6f9c81bc0c0d6d91773ffad@pgbouncer:5432/tribes
