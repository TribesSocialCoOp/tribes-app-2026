<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Staging entitlements for the app.tribes.TribesApp.staging build flavor.
  Identical to App.entitlements except:
    - associated-domains point at staging.tribes.app (passkeys + universal links)
    - the Apple Pay (in-app-payments) entitlement is omitted — billing is disabled
      on staging (BILLING_ENABLED=false), and it would otherwise require a separate
      merchant ID provisioned on the staging App ID.
  Selected at build time via CODE_SIGN_ENTITLEMENTS in scripts/build_ios.sh --staging.
  The staging App ID must have Associated Domains, Sign in with Apple, and NFC Tag
  Reading capabilities enabled in the Developer portal.
-->
<plist version="1.0">
<dict>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:staging.tribes.app</string>
		<string>webcredentials:staging.tribes.app</string>
	</array>
	<key>com.apple.developer.nfc.readersession.formats</key>
	<array>
		<string>TAG</string>
	</array>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!-- Declared Age Range API (iOS 26.2+) — NSFW 18+ gate. Requires the capability
	     enabled on the staging App ID in the Developer portal. -->
	<key>com.apple.developer.declared-age-range</key>
	<true/>
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
