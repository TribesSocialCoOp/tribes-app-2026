# ============================================================
# Tribes.app — Environment Variables
# ============================================================
# Copy to .env.local and fill in your values.
# Variables marked [REQUIRED] must be set for the feature to work.
# Variables marked [OPTIONAL] have sensible defaults.
#
# Phase annotations:
#   [P1] — Required for Closed Alpha (single node, ≤50 users)
#   [P2] — Required for Private Beta (managed services, ≤500 users)
#   [P3] — Required for General Availability

# === Session & Security [P1] ===
# [REQUIRED in production] — JWT signing key for sessions, CAPTCHA, and WS tokens.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# [OPTIONAL] Set to 'true' to enforce CSRF validation in development.
# CSRF is always enforced in production.
# ENFORCE_CSRF=true

# [REQUIRED in production] — Next.js Server Actions Encryption Key
# Without this, every build generates new random encryption keys, which invalidates and breaks
# client-side server action references upon redeploys or container restarts.
# Generate with: openssl rand -hex 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=


# === AI Configuration [P1] ===
# Works with any OpenAI-compatible endpoint: vLLM, Ollama, llama.cpp, LiteLLM
AI_BASE_URL=http://localhost:8000/v1
AI_API_KEY=not-needed-for-local
AI_MODEL=default

# === Database [P1] ===
# [OPTIONAL] Local Postgres URL. Defaults to postgresql://tribes:tribes_dev@localhost:5432/tribes
# DATABASE_URL=postgresql://tribes:tribes_dev@localhost:5432/tribes

# === WebAuthn / Passkeys [P1] ===
# [REQUIRED] Change for production domain.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Tribes.app
WEBAUTHN_ORIGIN=http://localhost:9002
# Production example:
# WEBAUTHN_RP_ID=tribes.app
# WEBAUTHN_ORIGIN=https://tribes.app
# [OPTIONAL] Android native origin for Capacitor passkey bridge.
# Format: android:apk-key-hash:<base64url-sha256-cert-fingerprint>
# Derived from the SHA-256 signing cert fingerprint in assetlinks.json.
# Supports a comma-separated list of multiple Android origins (e.g. for release and local debug).
# WEBAUTHN_ANDROID_ORIGIN=android:apk-key-hash:...
# [OPTIONAL] Verbose passkey debugging for troubleshooting logins. Set a credential prefix (e.g., first few characters of a credential ID) to log detailed crypto details.
# PASSKEY_DEBUG_CREDENTIAL_PREFIX=



# === Google OAuth [P1] ===
# [REQUIRED for Google login] — Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:9002/api/auth/google/callback

# === Apple Sign-In (OIDC) [P2] ===
# [REQUIRED for Apple login] — Configure at https://developer.apple.com/account/resources
# APPLE_CLIENT_ID=app.tribes.web
# APPLE_TEAM_ID=ABXVW6PWCW
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=./keys/apple-signin.p8

# === Dev Login Bypass [P1] ===
# [REQUIRED for dev login] — Must be set to 'local-dev-only' for dev bypass to work.
DEV_BYPASS_SECRET=local-dev-only

# === S3 Media Storage (SeaweedFS / MinIO / any S3-compatible) [P1] ===
# [REQUIRED for file uploads]
S3_ENDPOINT="http://localhost:8333"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="tribes-dev-key"
S3_SECRET_ACCESS_KEY="tribes-dev-secret"
S3_BUCKET_NAME="tribes-media"
S3_PUBLIC_ENDPOINT="http://localhost:8888"

# === Stripe Payments [P1] ===
# [REQUIRED for billing features]
# Set to 'true' to enable billing UI and checkout forms.
# BILLING_ENABLED=true
# Use sk_test_/pk_test_ for development, sk_live_/pk_live_ for production
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# === Email (SMTP) [P1] ===
# [REQUIRED for transactional emails]
# In dev mode, emails are logged to console as JSON instead of sent.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Tribes.app" <noreply@tribes.app>

# === WebSocket Relay [P1] ===
# [REQUIRED for real-time messaging between bonds]
# The WS relay is a separate Node.js process (ws-relay/server.js).
NEXT_PUBLIC_WS_RELAY_URL=ws://localhost:9003
# Shared secret authenticating the app <-> ws-relay internal channel (the app POSTs
# to the relay's /internal/push, the relay calls back into /api/internal/*). MUST be
# the SAME value in the app and the relay (both read this var). REQUIRED in production
# — if unset there, internal pushes fail closed (no insecure default). In local dev a
# built-in 'dev-only-internal-secret' is used when this is blank, so you can leave it
# unset locally. Generate with: openssl rand -hex 32
# INTERNAL_API_SECRET=

# === Cron Jobs [P1] ===
# [REQUIRED for cron endpoints] — Shared secret for cron authentication
# Generate with: openssl rand -hex 16
# CRON_SECRET=

# === App URL [P1] ===
# [REQUIRED in production] Used for email links, WebAuthn origin, etc.
NEXT_PUBLIC_APP_URL=http://localhost:9002

# === Rate Limiting (Valkey) [P2] ===
# In-memory by default (single instance). Set VALKEY_URL to enable distributed rate limiting.
# In Docker Compose: redis://valkey:6379
# VALKEY_URL=redis://valkey:6379

# === Push Notifications (VAPID) [P1] ===
# Web push notification credentials. Generate with: npx web-push generate-vapid-keys --json
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@tribes.app

# === Bot Protection [P2] ===
# Cloudflare Turnstile bot protection (site key is safe to be public).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
#
# ALTCHA Proof-of-Work bot protection (self-hosted, no third-party scripts/DNS required).
# Generate a 32-byte hex secret with: openssl rand -hex 32
# ALTCHA_HMAC_SECRET=

# === Feature Flags & Sign-In Options [P1] ===
# Enabled authentication methods (comma-separated list of: passkey, password, google, apple)
# Default if unset: passkey,password,google,apple
# AUTH_METHODS=passkey,password,google,apple
# NEXT_PUBLIC_AUTH_METHODS=passkey,password,google,apple
#
# Invite gating. Default (false/unset): OPEN registration — anyone can sign up, and an
# invite code is OPTIONAL (still redeemable for its perks: plan/role, referral bond).
# Set to 'true' to REQUIRE a validated invite code to register (invite-only mode).
# NOTE: NEXT_PUBLIC_* is baked into the client bundle at BUILD time — flipping it needs a rebuild.
# NEXT_PUBLIC_INVITE_ONLY=false


# === Logging [P1] ===
# Log level: trace < debug < info < warn < error < fatal
# Default: info. Use 'debug' for development.
# LOG_LEVEL=info

# === CSAM Detection (PDQ + NCMEC) [Required before accepting public uploads] ===
# PDQ perceptual hashing runs locally (open source, no API key needed).
# Register with NCMEC ESP program to get hash list + reporting credentials:
#   Email: espteam@ncmec.org  |  Subject: ESP Registration — Tribes.app
#
# PDQ_HASH_LIST_PATH=./data/ncmec-hashes.bin   # Path to NCMEC hash list file
# NCMEC_ESP_ID=                                 # Your NCMEC ESP ID
# NCMEC_ESP_PASSWORD=                           # Your NCMEC ESP password
# NCMEC_SKIP_REPORT=false                       # Set true ONLY in test environments


# === NSFW Age Verification — Wallet Providers (issue #32) [Required before NSFW launch] ===
# Privacy-preserving 18+ verification for NSFW Tribes. The app is the VERIFIER (relying
# party): it asks the user's Google/Apple Wallet "is this person 18+?" and gets a signed
# yes/no. We store ONLY the pass/fail outcome — never a name, birthdate, or ID.
#
# Full walkthrough (how to get the keys + how to test): docs/testing-wallet-age-verification.md
#
# ── STAGE GATE ──────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_WALLET_VERIFY_ENABLED gates the whole wallet-verify feature. It is OFF by
# default: Stage 1 launches with self-attestation in open regions and GEO-BLOCKS the ~27
# US law states (no verification method to offer them yet). Set it to `true` — per env
# (dev/staging first, prod once you've device-tested Google Wallet) — to re-open the
# `verify` tier AND surface the Google Wallet provider. The two ungate together.
# NEXT_PUBLIC_* is baked in at BUILD time, so flipping it needs a rebuild.
# NEXT_PUBLIC_WALLET_VERIFY_ENABLED=false
#
# Each wallet provider's button only appears once WALLET_VERIFY is enabled AND all of that
# provider's REQUIRED vars below are set. While the stage gate is off (default), the wallet
# providers stay hidden even if configured.
#
# ── iOS DECLARED AGE RANGE (independent of Wallet) ───────────────────────────────────
# Apple's Declared Age Range API (iOS 26.2+ native only) is a SECOND verification method
# that can unblock iPhone users in the law states WITHOUT Google Wallet. OFF by default.
# When true, an iOS-native law-state user gets the OS age-check step instead of the
# blocked screen. NEXT_PUBLIC_* → baked in at build, needs a rebuild to flip.
# NEXT_PUBLIC_IOS_AGE_VERIFY_ENABLED=false
#
# Apple's result is NOT cryptographically signed, so it's only trusted in PRODUCTION once
# App Attest verification is implemented (Phase 2). Until then the server prod-rejects it
# even with the flag on (dev/staging testing still works). Do NOT set this in prod until
# App Attest lands:
# IOS_AGE_APP_ATTEST_ENABLED=false
#
# PEM values are multi-line. In .env files, wrap the whole block in double quotes and keep
# the real line breaks (Next.js @next/env supports multi-line double-quoted values), e.g.:
#   GOOGLE_WALLET_READER_KEY_PEM="-----BEGIN EC PRIVATE KEY-----
#   MHcCAQ...
#   -----END EC PRIVATE KEY-----"
# Alternatively put it on one line using \n between lines.
#
# ⚠️ Use SANDBOX credentials for testing and PRODUCTION credentials for production —
#    never the sandbox keys in prod. Never commit real keys; these are stubs only.

# --- Google Wallet (Verify with Google Wallet) ---
# Sandbox keys + allowlisting: https://developers.google.com/wallet/identity/verify/sandbox
# [REQUIRED] client_id = the x509 hash of your RP certificate (sandbox- or prod-issued)
# GOOGLE_WALLET_RP_ID=
# [REQUIRED] RP private key (PEM) used to JWS-sign the credential request
# GOOGLE_WALLET_READER_KEY_PEM=
# [REQUIRED] RP certificate (PEM) embedded in the request's x5c header
# GOOGLE_WALLET_READER_CERT_PEM=
# [REQUIRED] Issuer/IACA trust-anchor cert(s) (PEM; concatenate multiple) to verify responses
# GOOGLE_WALLET_IACA_PEM=
# [OPTIONAL] base64url CBOR RP metadata (display name / logo / privacy policy)
# GOOGLE_WALLET_RP_METADATA=
# [OPTIONAL] mdoc doctype to request (default: org.iso.18013.5.1.mDL)
# GOOGLE_WALLET_DOCTYPE=org.iso.18013.5.1.mDL
# [OPTIONAL] namespace holding age_over_18 (default: org.iso.18013.5.1)
# GOOGLE_WALLET_NAMESPACE=org.iso.18013.5.1

# --- Apple Wallet (ID in Wallet: state mDL or US-passport Digital ID) ---
# Same shape as Google. Verified through the W3C Digital Credentials API in iOS 26 WebKit.
# APPLE_WALLET_RP_ID=
# APPLE_WALLET_READER_KEY_PEM=
# APPLE_WALLET_READER_CERT_PEM=
# APPLE_WALLET_IACA_PEM=
# APPLE_WALLET_RP_METADATA=
# APPLE_WALLET_DOCTYPE=org.iso.18013.5.1.mDL
# APPLE_WALLET_NAMESPACE=org.iso.18013.5.1

# --- Shared age-verification settings ---
# [OPTIONAL] Exact origin allowlist for verification requests (defense-in-depth). If set,
# the request origin must match exactly. Example: https://tribes.app
# APP_ORIGIN=
# NOTE: the DEV age-verification provider (exercise the gate without a wallet) is enabled
# purely by NODE_ENV !== 'production' — no env flag. It is hard-off in production.
# NOTE: SESSION_SECRET (top of this file) is also REQUIRED — it seals the verification
# state (nonce + ephemeral decryption key) passed through the wallet round-trip.
#
# --- NSFW geo gate (issue #32) ---
# The gate resolves region from a LOCAL MaxMind GeoLite2-City .mmdb (free license at
# maxmind.com). Lookup is in-process — the user's IP is never sent to a third party
# and neither IP nor region is stored. Without a DB, every region resolves to 'open'
# (self-attest) and the verify tier + UK block are INERT.
#
# THE ONLY VARS YOU SET: the two MaxMind creds below. With them, remote_deploy.sh
# auto-fetches the DB to /opt/tribes/geoip/ before the app starts and installs a
# weekly refresh cron. (No creds? rsync the .mmdb to /opt/tribes/geoip/ yourself.)
# GEOIPUPDATE_ACCOUNT_ID=
# GEOIPUPDATE_LICENSE_KEY=
#
# NOTE — GEOIP_DB_PATH (where the app reads the .mmdb) is set AUTOMATICALLY by
# docker-compose.prod.yml to /app/geoip/GeoLite2-City.mmdb (the host's ./geoip
# mounted in-container). Do NOT set it here. Only set it if you run WITHOUT our
# Docker compose, pointing at wherever your .mmdb lives.
#
# [DEV/TEST ONLY] Force a region without a DB: US-KS (verify) / GB (block) / US-CA (open).
# AGE_GEO_OVERRIDE=US-KS


# ── Capacitor Mobile Development ──────────────────────────────────────
# Your LAN IP for Android/iOS live-reload (used by next.config.ts)
# CAPACITOR_DEV_HOST=192.168.1.42
