# ============================================================
# Tribes.app — Environment Variables
# ============================================================
# Copy to .env.local and fill in your values.
# Variables marked [REQUIRED] must be set for the feature to work.
# Variables marked [OPTIONAL] have sensible defaults.
#
# Phase annotations:
#   [P1] — Required for Closed Alpha (single node, ≤50 users)
#   [P2] — Required for Private Beta (managed services, ≤500 users)
#   [P3] — Required for General Availability

# === Session & Security [P1] ===
# [REQUIRED in production] — JWT signing key for sessions, CAPTCHA, and WS tokens.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# [OPTIONAL] Set to 'true' to enforce CSRF validation in development.
# CSRF is always enforced in production.
# ENFORCE_CSRF=true

# [REQUIRED in production] — Next.js Server Actions Encryption Key
# Without this, every build generates new random encryption keys, which invalidates and breaks
# client-side server action references upon redeploys or container restarts.
# Generate with: openssl rand -hex 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=


# === AI Configuration [P1] ===
# Works with any OpenAI-compatible endpoint: vLLM, Ollama, llama.cpp, LiteLLM
AI_BASE_URL=http://localhost:8000/v1
AI_API_KEY=not-needed-for-local
AI_MODEL=default

# === Database [P1] ===
# [OPTIONAL] Local Postgres URL. Defaults to postgresql://tribes:tribes_dev@localhost:5432/tribes
# DATABASE_URL=postgresql://tribes:tribes_dev@localhost:5432/tribes

# === WebAuthn / Passkeys [P1] ===
# [REQUIRED] Change for production domain.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Tribes.app
WEBAUTHN_ORIGIN=http://localhost:9002
# Production example:
# WEBAUTHN_RP_ID=tribes.app
# WEBAUTHN_ORIGIN=https://tribes.app
# [OPTIONAL] Android native origin for Capacitor passkey bridge.
# Format: android:apk-key-hash:<base64url-sha256-cert-fingerprint>
# Derived from the SHA-256 signing cert fingerprint in assetlinks.json.
# Supports a comma-separated list of multiple Android origins (e.g. for release and local debug).
# WEBAUTHN_ANDROID_ORIGIN=android:apk-key-hash:...
# [OPTIONAL] Verbose passkey debugging for troubleshooting logins. Set a credential prefix (e.g., first few characters of a credential ID) to log detailed crypto details.
# PASSKEY_DEBUG_CREDENTIAL_PREFIX=



# === Google OAuth [P1] ===
# [REQUIRED for Google login] — Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:9002/api/auth/google/callback

# === Apple Sign-In (OIDC) [P2] ===
# [REQUIRED for Apple login] — Configure at https://developer.apple.com/account/resources
# APPLE_CLIENT_ID=app.tribes.web
# APPLE_TEAM_ID=ABXVW6PWCW
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=./keys/apple-signin.p8

# === Dev Login Bypass [P1] ===
# [REQUIRED for dev login] — Must be set to 'local-dev-only' for dev bypass to work.
DEV_BYPASS_SECRET=local-dev-only

# === S3 Media Storage (SeaweedFS / MinIO / any S3-compatible) [P1] ===
# [REQUIRED for file uploads]
S3_ENDPOINT="http://localhost:8333"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="tribes-dev-key"
S3_SECRET_ACCESS_KEY="tribes-dev-secret"
S3_BUCKET_NAME="tribes-media"
S3_PUBLIC_ENDPOINT="http://localhost:8888"

# === Stripe Payments [P1] ===
# [REQUIRED for billing features]
# Set to 'true' to enable billing UI and checkout forms.
# BILLING_ENABLED=true
# Use sk_test_/pk_test_ for development, sk_live_/pk_live_ for production
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# === Email (SMTP) [P1] ===
# [REQUIRED for transactional emails]
# In dev mode, emails are logged to console as JSON instead of sent.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Tribes.app" <noreply@tribes.app>

# === WebSocket Relay [P1] ===
# [REQUIRED for real-time messaging between bonds]
# The WS relay is a separate Node.js process (ws-relay/server.js).
NEXT_PUBLIC_WS_RELAY_URL=ws://localhost:9003

# === Cron Jobs [P1] ===
# [REQUIRED for cron endpoints] — Shared secret for cron authentication
# Generate with: openssl rand -hex 16
# CRON_SECRET=

# === App URL [P1] ===
# [REQUIRED in production] Used for email links, WebAuthn origin, etc.
NEXT_PUBLIC_APP_URL=http://localhost:9002

# === Rate Limiting (Valkey) [P2] ===
# In-memory by default (single instance). Set VALKEY_URL to enable distributed rate limiting.
# In Docker Compose: redis://valkey:6379
# VALKEY_URL=redis://valkey:6379

# === Push Notifications (VAPID) [P1] ===
# Web push notification credentials. Generate with: npx web-push generate-vapid-keys --json
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@tribes.app

# === Bot Protection [P2] ===
# Cloudflare Turnstile bot protection (site key is safe to be public).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
#
# ALTCHA Proof-of-Work bot protection (self-hosted, no third-party scripts/DNS required).
# Generate a 32-byte hex secret with: openssl rand -hex 32
# ALTCHA_HMAC_SECRET=

# === Feature Flags & Sign-In Options [P1] ===
# Enabled authentication methods (comma-separated list of: passkey, password, google, apple)
# Default if unset: passkey,password,google,apple
# AUTH_METHODS=passkey,password,google,apple
# NEXT_PUBLIC_AUTH_METHODS=passkey,password,google,apple
#
# Require a validated invite code to sign up.
# NEXT_PUBLIC_INVITE_ONLY=true


# === Logging [P1] ===
# Log level: trace < debug < info < warn < error < fatal
# Default: info. Use 'debug' for development.
# LOG_LEVEL=info

# === CSAM Detection (PDQ + NCMEC) [Required before accepting public uploads] ===
# PDQ perceptual hashing runs locally (open source, no API key needed).
# Register with NCMEC ESP program to get hash list + reporting credentials:
#   Email: espteam@ncmec.org  |  Subject: ESP Registration — Tribes.app
#
# PDQ_HASH_LIST_PATH=./data/ncmec-hashes.bin   # Path to NCMEC hash list file
# NCMEC_ESP_ID=                                 # Your NCMEC ESP ID
# NCMEC_ESP_PASSWORD=                           # Your NCMEC ESP password
# NCMEC_SKIP_REPORT=false                       # Set true ONLY in test environments


# ── Capacitor Mobile Development ──────────────────────────────────────
# Your LAN IP for Android/iOS live-reload (used by next.config.ts)
# CAPACITOR_DEV_HOST=192.168.1.42
